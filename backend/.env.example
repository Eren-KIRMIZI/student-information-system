DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/obs_db"

# Secret'lar production'da cryptographically random olmali:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate_random_64_bytes_for_production"
JWT_REFRESH_SECRET="generate_different_random_64_bytes_for_production"
JWT_RESET_SECRET="generate_yet_another_random_64_bytes_for_production"
ACCESS_TOKEN_EXPIRES="15m"
REFRESH_TOKEN_EXPIRES="7d"

PORT=5000
NODE_ENV="development"

CORS_ORIGIN="http://localhost:5173"

MAX_ECTS_PER_SEMESTER=45

REDIS_URL="redis://:your_redis_password@127.0.0.1:6379"

# Opsiyonel - Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
