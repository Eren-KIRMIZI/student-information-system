generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum RoleName {
  ADMIN
  ACADEMICIAN
  STUDENT
}

enum Semester {
  FALL
  SPRING
  SUMMER
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  DROPPED
}

enum LetterGrade {
  AA
  BA
  BB
  CB
  CC
  DC
  DD
  FD
  FF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

enum AnnouncementCategory {
  GENERAL
  ACADEMIC
  EXAM
  EVENT
}

enum TargetRole {
  ALL
  STUDENT
  ACADEMICIAN
  ADMIN
}

enum CalendarCategory {
  REGISTRATION
  EXAM
  HOLIDAY
  SEMESTER_START
  SEMESTER_END
  OTHER
}

enum ExamType {
  MIDTERM
  FINAL
  MAKEUP
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UploadPurpose {
  PROFILE_PHOTO
  COURSE_MATERIAL
  OTHER
}

enum CourseType {
  REQUIRED
  ELECTIVE
  COMMON
  DEPARTMENT_ELECTIVE
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
  EXPIRED
}

// ==================== AUTH ====================

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  users       User[]

  @@map("roles")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student       Student?
  lecturer      Lecturer?
  refreshTokens RefreshToken[]
  uploads       Upload[]
  logs          Log[]
  announcements Announcement[]
  qrTokens      QRToken[]
  materials     CourseMaterial[]
  conversations ConversationParticipant[]
  messages      Message[] @relation("SentMessages")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ==================== ORGANIZATION ====================

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique
  code        String       @unique
  departments Department[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("faculties")
}

model Department {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  facultyId String
  faculty   Faculty    @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  students  Student[]
  lecturers Lecturer[]
  courses   Course[]
  graduationRequirement GraduationRequirement?
  courseGroups CourseGroup[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([facultyId])
  @@map("departments")
}

// ==================== PEOPLE ====================

model Student {
  id             String              @id @default(cuid())
  userId         String              @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNumber  String              @unique
  nationalId     String              @unique
  firstName      String
  lastName       String
  phone          String?
  address        String?
  birthDate      DateTime?
  photoUrl       String?
  classYear      Int                 @default(1)
  gpa            Float               @default(0)
  departmentId   String
  department     Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  enrollments    Enrollment[]
  advisorHistory AdvisorAssignment[]
  waitlist       Waitlist[]
  qrScans        QRScan[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([departmentId])
  @@index([userId])
  @@map("students")
}

model Lecturer {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  title             String
  phone             String?
  photoUrl          String?
  departmentId      String
  department        Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  sections          CourseSection[]
  advisees          AdvisorAssignment[]
  supervising       ExamSchedule[]
  gradesGiven       Grade[]
  attendanceRecords Attendance[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([departmentId])
  @@index([userId])
  @@map("lecturers")
}

model AdvisorAssignment {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lecturerId   String
  lecturer     Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  academicYear String
  isActive     Boolean  @default(true)
  assignedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([studentId, lecturerId, academicYear])
  @@map("advisor_assignments")
}

// ==================== ACADEMIC STRUCTURE ====================

model Course {
  id           String          @id @default(cuid())
  code         String          @unique
  name         String
  credit       Int
  ects         Int
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  description  String?
  courseType   CourseType      @default(REQUIRED)
  sections     CourseSection[]
  prerequisites  Prerequisite[]  @relation("RequiredCourse")
  requiredBy     Prerequisite[]  @relation("PrereqCourse")
  groupItems     CourseGroupItem[]
  createdAt      DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([departmentId])
  @@map("courses")
}

model CourseSection {
  id           String           @id @default(cuid())
  courseId     String
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  lecturerId   String
  lecturer     Lecturer         @relation(fields: [lecturerId], references: [id], onDelete: Restrict)
  academicYear String
  semester     Semester
  quota        Int
  classroom    String?
  isArchived   Boolean          @default(false)
  enrollments  Enrollment[]
  weeklySlots  WeeklySchedule[]
  examSlots    ExamSchedule[]
  materials    Upload[]
  courseMaterials CourseMaterial[]
  waitlist     Waitlist[]
  qrTokens     QRToken[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([courseId, academicYear, semester, lecturerId])
  @@index([academicYear, semester])
  @@map("course_sections")
}

// ==================== ENROLLMENT & GRADES ====================

model Enrollment {
  id              String           @id @default(cuid())
  studentId       String
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Restrict)
  courseSectionId String
  courseSection   CourseSection    @relation(fields: [courseSectionId], references: [id], onDelete: Restrict)
  status          EnrollmentStatus @default(PENDING)
  enrolledAt      DateTime         @default(now())
  grade           Grade?
  attendance      Attendance[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([studentId, courseSectionId])
  @@index([status])
  @@index([studentId])
  @@index([courseSectionId])
  @@index([studentId, status])
  @@map("enrollments")
}

model Grade {
  id           String       @id @default(cuid())
  enrollmentId String       @unique
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  midtermScore Float?
  finalScore   Float?
  makeupScore  Float?
  letterGrade  LetterGrade?
  gradePoint   Float?
  isFinalized  Boolean      @default(false)
  enteredById  String?
  enteredBy    Lecturer?    @relation(fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("grades")
}

model Attendance {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  date         DateTime
  status       AttendanceStatus
  recordedById String?
  recordedBy   Lecturer?        @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@unique([enrollmentId, date])
  @@index([enrollmentId])
  @@index([date])
  @@map("attendance")
}

// ==================== SCHEDULE ====================

model WeeklySchedule {
  id              String        @id @default(cuid())
  courseSectionId String
  courseSection   CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  dayOfWeek       DayOfWeek
  startTime       String        // "09:00" formatı
  endTime         String
  classroom       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("weekly_schedule")
}

model ExamSchedule {
  id              String        @id @default(cuid())
  courseSectionId String
  courseSection   CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  examType        ExamType
  examDate        DateTime
  startTime       String
  endTime         String
  classroom       String
  supervisorId    String?
  supervisor      Lecturer?     @relation(fields: [supervisorId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("exam_schedule")
}

// ==================== CONTENT ====================

model Announcement {
  id            String               @id @default(cuid())
  title         String
  content       String
  category      AnnouncementCategory @default(GENERAL)
  targetRole    TargetRole           @default(ALL)
  publishedById String
  publishedBy   User                 @relation(fields: [publishedById], references: [id], onDelete: Restrict)
  publishedAt   DateTime             @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([targetRole, publishedAt])
  @@index([category])
  @@map("announcements")
}

model AcademicCalendar {
  id          String           @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  category    CalendarCategory @default(OTHER)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([startDate, endDate])
  @@map("academic_calendar")
}

// ==================== SYSTEM ====================

model Upload {
  id              String         @id @default(cuid())
  uploaderId      String
  uploader        User           @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  fileName        String
  originalName    String
  mimeType        String
  size            Int
  path            String
  purpose         UploadPurpose  @default(OTHER)
  courseSectionId String?
  courseSection   CourseSection? @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([uploaderId])
  @@map("uploads")
}

model Log {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("logs")
}

// ==================== ENTERPRISE: AUDIT LOG ====================

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String
  entity        String
  entityId      String?
  method        String
  path          String
  ipAddress     String?
  userAgent     String?
  correlationId String?
  before        Json?
  after         Json?
  statusCode    Int?
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([correlationId])
  @@map("audit_logs")
}

// ==================== ENTERPRISE: SYSTEM SETTINGS ====================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([key])
  @@index([category])
  @@map("system_settings")
}

// ==================== ENTERPRISE: IDEMPOTENCY ====================

model IdempotencyRecord {
  id         String   @id @default(cuid())
  key        String   @unique
  statusCode Int
  response   Json
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ==================== ADVANCED: PREREQUISITES ====================

model Prerequisite {
  id              String  @id @default(cuid())
  courseId         String
  requiredCourse   Course           @relation("RequiredCourse", fields: [courseId], references: [id], onDelete: Cascade)
  prereqCourseId   String
  prereqCourse     Course           @relation("PrereqCourse", fields: [prereqCourseId], references: [id], onDelete: Cascade)
  minGradePoint    Float?

  @@unique([courseId, prereqCourseId])
  @@map("prerequisites")
}

// ==================== ADVANCED: WAITLIST ====================

model Waitlist {
  id              String         @id @default(cuid())
  studentId       String
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseSectionId String
  courseSection   CourseSection  @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  position        Int
  status          WaitlistStatus @default(WAITING)
  enrolledAt      DateTime       @default(now())
  promotedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([studentId, courseSectionId])
  @@index([courseSectionId, status])
  @@map("waitlist")
}

// ==================== ADVANCED: QR ATTENDANCE ====================

model QRToken {
  id              String        @id @default(cuid())
  courseSectionId String
  courseSection   CourseSection @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  token           String        @unique
  expiresAt       DateTime
  isActive        Boolean       @default(true)
  createdBy       String
  createdByUser   User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  scans           QRScan[]
  createdAt       DateTime      @default(now())

  @@index([token])
  @@index([courseSectionId, isActive])
  @@map("qr_tokens")
}

model QRScan {
  id        String   @id @default(cuid())
  tokenId   String
  token     QRToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scannedAt DateTime @default(now())

  @@unique([tokenId, studentId])
  @@map("qr_scans")
}

// ==================== ADVANCED: GRADUATION REQUIREMENTS ====================

model GraduationRequirement {
  id             String   @id @default(cuid())
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  totalEcts      Int      @default(240)
  minGpa         Float    @default(2.0)
  maxFfCount     Int      @default(0)
  requiredCredits Int     // zorunlu ders kredisi
  maxRetakes     Int      @default(3)
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([departmentId])
  @@map("graduation_requirements")
}

// ==================== ADVANCED: COURSE PREREQUISITE GROUPS ====================

model CourseGroup {
  id          String          @id @default(cuid())
  name        String
  departmentId String
  department  Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  minCredits  Int
  courses     CourseGroupItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("course_groups")
}

model CourseGroupItem {
  id          String      @id @default(cuid())
  groupId     String
  group       CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  courseId     String
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isRequired  Boolean     @default(false)

  @@unique([groupId, courseId])
  @@map("course_group_items")
}

// ==================== ADVANCED: COURSE MATERIALS ====================

model CourseMaterial {
  id               String         @id @default(cuid())
  title            String
  description      String?
  week             Int?
  originalFileName String
  storageKey       String
  fileUrl          String
  fileType         String
  extension        String
  fileSize         Int
  visibility       String         @default("STUDENTS")
  downloadCount    Int            @default(0)
  uploaderId       String
  uploader         User           @relation(fields: [uploaderId], references: [id])
  courseSectionId  String
  courseSection    CourseSection  @relation(fields: [courseSectionId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([courseSectionId])
  @@index([uploaderId])
  @@map("course_materials")
}

// ==================== ADVANCED: MESSAGING ====================

model Conversation {
  id            String   @id @default(cuid())
  isGroup       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime?
  lastMessageId String?
  participants  ConversationParticipant[]
  messages      Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  editedAt       DateTime?
  deletedAt      DateTime?

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}
